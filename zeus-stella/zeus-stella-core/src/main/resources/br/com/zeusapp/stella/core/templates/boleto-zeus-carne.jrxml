<?xml version="1.0" encoding="UTF-8"?>
<!-- Zeus Stella — Boleto Carnê (3 por página A4) com suporte a PIX              -->
<!-- Adaptado de boleto-carne.jrxml (caelum-stella / stella-boleto)               -->
<!-- Principais diferenças vs. original:                                           -->
<!--   - Campos do modelo plano BoletoReportModel (sem navegação aninhada)         -->
<!--   - Datas como java.util.Date (não Calendar)                                  -->
<!--   - Barcode via parâmetro BARCODE_IMAGE (byte[], ZXing ITF)                   -->
<!--   - Parâmetros QRCODE_IMAGE e EXIBIR_PIX declarados (reservados para futura   -->
<!--     exibição de QR Code Pix no layout de carnê)                               -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="boleto-zeus-carne"
              pageWidth="595" pageHeight="842"
              columnWidth="595"
              leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0"
              uuid="ee1a2b3c-4d5e-6f70-8900-aabbccddeeff">

  <!-- ─── Styles ───────────────────────────────────────────────────────────── -->
  <style name="Label" forecolor="#646464" fontName="Arial" fontSize="5"
         isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false">
    <box topPadding="1" leftPadding="2" bottomPadding="1" rightPadding="1"/>
  </style>
  <style name="Value" fontName="Arial" fontSize="6" isBold="false">
    <box topPadding="1" leftPadding="2" bottomPadding="1" rightPadding="1"/>
  </style>
  <style name="ValueBold" fontName="Arial" fontSize="6" isBold="true">
    <box topPadding="1" leftPadding="2" bottomPadding="1" rightPadding="2"/>
  </style>
  <style name="ValueRight" fontName="Arial" fontSize="6" isBold="true" hAlign="Right">
    <box topPadding="1" leftPadding="1" bottomPadding="1" rightPadding="3"/>
  </style>
  <style name="ValueDate" fontName="Arial" fontSize="6" isBold="true" hAlign="Right"
         pattern="dd/MM/yyyy">
    <box topPadding="1" leftPadding="1" bottomPadding="1" rightPadding="3"/>
  </style>
  <style name="BankNum" fontName="Arial" fontSize="11" isBold="true" hAlign="Center" vAlign="Middle"/>
  <style name="DigLine" fontName="Arial" fontSize="7" vAlign="Middle">
    <box topPadding="1" leftPadding="4" bottomPadding="1" rightPadding="2"/>
  </style>
  <style name="Footer" fontName="Arial" fontSize="5" isBold="false" forecolor="#646464">
    <box topPadding="1" leftPadding="2" bottomPadding="1" rightPadding="2"/>
  </style>
  <style name="FooterItalic" fontName="Arial" fontSize="5" isItalic="true" forecolor="#646464" hAlign="Right">
    <box topPadding="1" leftPadding="2" bottomPadding="1" rightPadding="2"/>
  </style>

  <!-- ─── SubDataset instrucoes ─────────────────────────────────────────────── -->
  <subDataset name="instrucoes_ds" uuid="aa110011-bb22-cc33-dd44-ee5566778800">
    <queryString language="SQL"><![CDATA[]]></queryString>
    <field name="instrucao" class="java.lang.String">
      <fieldDescription><![CDATA[_THIS]]></fieldDescription>
    </field>
  </subDataset>

  <!-- ─── Parâmetros ─────────────────────────────────────────────────────────── -->
  <!-- BARCODE_IMAGE : byte[] PNG do código de barras ITF (gerado pelo GeradorDeQRCode) -->
  <!-- QRCODE_IMAGE  : byte[] PNG do QR Code EMV Pix (reservado para futura exibição)  -->
  <!-- EXIBIR_PIX    : Boolean — quando true, exibe QR Code (não implementado no carnê)  -->
  <parameter name="BARCODE_IMAGE"  class="java.io.InputStream" isForPrompting="false"/>
  <parameter name="QRCODE_IMAGE"   class="java.io.InputStream" isForPrompting="false"/>
  <parameter name="EXIBIR_PIX"     class="java.lang.Boolean"   isForPrompting="false">
    <defaultValueExpression><![CDATA[Boolean.FALSE]]></defaultValueExpression>
  </parameter>

  <!-- ─── Fields — planos, mapeados ao BoletoReportModel ──────────────────────
       Todas as datas são java.util.Date (não Calendar).
       Sem fieldDescription de caminho aninhado — JasperReports chama getXxx() direto.
  ──────────────────────────────────────────────────────────────────────────── -->
  <queryString><![CDATA[]]></queryString>

  <field name="nomeBeneficiario"           class="java.lang.String"/>
  <field name="documentoBeneficiario"      class="java.lang.String"/>
  <field name="nomePagador"                class="java.lang.String"/>
  <field name="documentoPagador"           class="java.lang.String"/>
  <field name="logradouroPagador"          class="java.lang.String"/>
  <field name="bairroPagador"              class="java.lang.String"/>
  <field name="cepPagador"                 class="java.lang.String"/>
  <field name="cidadePagador"              class="java.lang.String"/>
  <field name="ufPagador"                  class="java.lang.String"/>
  <field name="vencimento"                 class="java.util.Date"/>
  <field name="dataDocumento"              class="java.util.Date"/>
  <field name="dataProcessamento"          class="java.util.Date"/>
  <field name="valorCobrado"               class="java.math.BigDecimal"/>
  <field name="valorBoleto"                class="java.math.BigDecimal"/>
  <field name="agenciaECodigoBeneficiario" class="java.lang.String"/>
  <field name="nossoNumeroECodDocumento"   class="java.lang.String"/>
  <field name="numeroBancoComDigito"       class="java.lang.String"/>
  <field name="especieDocumento"           class="java.lang.String"/>
  <field name="especieMoeda"               class="java.lang.String"/>
  <field name="aceite"                     class="java.lang.Boolean"/>
  <field name="instrucoes"                 class="java.util.List"/>
  <field name="logoBanco"                  class="java.net.URL"/>
  <field name="localPagamento"             class="java.lang.String"/>
  <field name="linhaDigitavel"             class="java.lang.String"/>
  <field name="numeroDocumento"            class="java.lang.String"/>
  <field name="codigoDeBarras"             class="java.lang.String"/>
  <field name="carteira"                   class="java.lang.String"/>
  <field name="digitoNossoNumero"          class="java.lang.String"/>
  <field name="parcela"                    class="java.lang.String"/>
  <field name="totalParcelas"              class="java.lang.String"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       DETAIL BAND — 1 carnê por registro, 3 por página A4 (3×264=792≤842pt)
